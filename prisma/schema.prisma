// Consola interna: clientes comerciales del producto POS (no confundir con usuarios del tenant en el API del POS).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  LEAD
  PROVISIONED
  ACTIVE
  PAUSED
  CHURNED
}

enum DocumentKind {
  LICENSE
  CONTRACT
  OTHER
}

model Client {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyName  String
  contactName  String?
  contactEmail String
  phone        String?
  status       ClientStatus @default(LEAD)

  /// Enlace lógico al tenant en el API del POS (Organization.id)
  posOrganizationId String? @unique
  /// URL base del front del cliente (p. ej. https://pos.cliente.com)
  posClientBaseUrl  String?

  notes String? @db.Text

  documents  ClientDocument[]
  revenue    RevenueEntry[]
  emailLogs  OutboundEmailLog[]
  activities ActivityLog[]

  @@index([status])
  @@index([contactEmail])
}

model ClientDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  kind  DocumentKind
  title String
  /// Ruta o clave en almacenamiento; integrar más adelante
  fileKey String?

  @@index([clientId])
}

model RevenueEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  amount   Decimal  @db.Decimal(12, 2)
  currency String   @default("DOP")
  label    String?
  /// Fecha a la que corresponde el ingreso (p. ej. cierre de venta)
  occurredOn DateTime

  @@index([clientId])
  @@index([occurredOn])
}

model OutboundEmailLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  toEmail String
  subject String
  /// clave de plantilla o identificador interno
  template String?
  status  String
  error   String?  @db.Text

  @@index([clientId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  action  String
  detail  String?  @db.Text
  /// payload JSON con contexto
  metadata Json?

  @@index([createdAt])
}
