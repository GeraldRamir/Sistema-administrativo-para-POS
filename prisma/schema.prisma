generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                String             @id @default(cuid())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companyName       String
  contactName       String?
  contactEmail      String
  phone             String?
  status            ClientStatus       @default(LEAD)
  /// Enlace lógico al tenant en el API del POS (Organization.id)
  posOrganizationId String?            @unique
  /// URL base del front del cliente (p. ej. https://pos.cliente.com)
  posClientBaseUrl  String?
  notes             String?
  activities        ActivityLog[]
  documents         ClientDocument[]
  emailLogs         OutboundEmailLog[]
  revenue           RevenueEntry[]

  @@index([status])
  @@index([contactEmail])
}

model ClientDocument {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  clientId  String
  kind      DocumentKind
  title     String
  /// Ruta o clave en almacenamiento; integrar más adelante
  fileKey   String?
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RevenueEntry {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  clientId   String
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("DOP")
  label      String?
  /// Fecha a la que corresponde el ingreso (p. ej. cierre de venta)
  occurredOn DateTime
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([occurredOn])
}

model OutboundEmailLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  clientId  String?
  toEmail   String
  subject   String
  /// clave de plantilla o identificador interno
  template  String?
  status    String
  error     String?
  client    Client?  @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  clientId  String?
  action    String
  detail    String?
  /// payload JSON con contexto
  metadata  Json?
  client    Client?  @relation(fields: [clientId], references: [id])

  @@index([createdAt])
}

enum ClientStatus {
  LEAD
  PROVISIONED
  ACTIVE
  PAUSED
  CHURNED
}

enum DocumentKind {
  LICENSE
  CONTRACT
  OTHER
}
