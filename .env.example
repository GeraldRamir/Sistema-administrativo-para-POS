# Consola de operaciones (pos-ops): su propia base (Neon u otra). Copie la URI real; no use hosts inventados.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Listado de usuarios (módulo Clientes): conecta al backend del POS.
# 1) Recomendado: POS_API_BASE_URL + POS_SERVICE_KEY (mismo valor que en el .env del pos-backend; el backend
#    usa la clave para: GET /auth/integration/organization/members y para generar el enlace al enviar
#    el correo de "activar contraseña" en Clientes, vía POST /auth/integration/password-setup-token).
# 2) Respaldo: si el API falla o faltan credenciales, se usa POS_DATABASE_URL (misma base PostgreSQL que el backend).
# Si solo define POS_API_BASE_URL sin clave y sin POS_DATABASE_URL, no habrá listado.
POS_API_BASE_URL="http://127.0.0.1:3001"
# POS_SERVICE_KEY=""
# POS_DATABASE_URL="postgresql://..."

# GET /organization/customers (público) en integraciones, sin variable extra

# URL pública de la app POS (enlaces en el correo de acceso / contraseña; plantilla fija en módulo Clientes)
# POS_APP_PUBLIC_URL="http://localhost:3000"

# --- Correo (módulo Clientes y Comunicados)
# Nombres soportados: EMAIL_* (abajo) o equivalencia SMTP_*.
# Prueba sin enviar: MAIL_LOG_ONLY=true (ver consola del servidor).
# Envío real: MAIL_LOG_ONLY=false y:
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="587"
# EMAIL_USER="su_cuenta@gmail.com"
# EMAIL_PASSWORD="contraseña de aplicación (Gmail)"
# EMAIL_FROM="Mi App <su_cuenta@gmail.com>"
# (Opcional) SMTP_SECURE="false" en 587; en 465 use true
MAIL_FROM="Operaciones <noreply@tudominio.com>"
